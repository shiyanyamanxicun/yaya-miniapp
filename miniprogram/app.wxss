page {
  --sky-top: #4A90D9;
  --sky-mid: #7BB3E0;
  --sky-bottom: #B8D9F0;
  --grass-green: #6DBE47;
  --grass-dark: #4CAF50;
  --cloud-white: #FFFFFF;
  --sun-yellow: #FFE082;
  --goat-cream: #FFFDF7;
  --text-dark: #3D2B30;
  --text-mid: #5A3A46;
  --pink-accent: #F8A0B0;

  font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
  background: #4A90D9;
  color: #3D2B30;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ===== 喜羊羊与灰太狼 — 青青草原主题背景 ===== */
.ghibli-bg {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 0;
  overflow: hidden;
  background:
    /* 太阳 */
    radial-gradient(circle at 85% 12%, rgba(255,255,200,0.7) 0%, rgba(255,240,150,0.3) 15%, transparent 35%),
    /* 大朵白云 */
    radial-gradient(ellipse at 20% 15%, rgba(255,255,255,0.75) 0%, rgba(255,255,255,0.3) 35%, transparent 55%),
    radial-gradient(ellipse at 55% 10%, rgba(255,255,255,0.65) 0%, rgba(255,255,255,0.2) 40%, transparent 60%),
    radial-gradient(ellipse at 75% 22%, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.15) 35%, transparent 50%),
    radial-gradient(ellipse at 10% 28%, rgba(255,255,255,0.4) 0%, transparent 40%),
    radial-gradient(ellipse at 40% 20%, rgba(255,255,255,0.35) 0%, transparent 30%),
    /* 蓝天渐变 */
    linear-gradient(180deg,
      #5B9BD5 0%,
      #6EA8DD 10%,
      #87C0EB 25%,
      #A8D5F2 42%,
      #C5E3F5 58%,
      #B8D9A8 70%,
      #7EC850 78%,
      #5DA83A 100%
    );
  opacity: 0.95;
}

/* 白云细节 */
.ghibli-bg::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 65%;
  background:
    /* 绵羊形状的云朵 */
    radial-gradient(ellipse at 15% 12%, rgba(255,255,255,0.7) 0%, rgba(255,255,255,0.2) 35%, transparent 50%),
    radial-gradient(ellipse at 22% 8%, rgba(255,255,255,0.55) 0%, transparent 30%),
    radial-gradient(ellipse at 50% 6%, rgba(255,255,255,0.65) 0%, rgba(255,255,255,0.2) 38%, transparent 55%),
    radial-gradient(ellipse at 58% 14%, rgba(255,255,255,0.45) 0%, transparent 28%),
    radial-gradient(ellipse at 35% 18%, rgba(255,255,255,0.5) 0%, transparent 35%),
    radial-gradient(ellipse at 72% 16%, rgba(255,255,255,0.4) 0%, transparent 32%),
    /* 远处小山丘 */
    radial-gradient(ellipse at 5% 55%, rgba(120,190,80,0.25) 0%, transparent 40%),
    radial-gradient(ellipse at 30% 52%, rgba(140,200,90,0.2) 0%, transparent 38%),
    radial-gradient(ellipse at 65% 58%, rgba(110,180,75,0.22) 0%, transparent 42%),
    radial-gradient(ellipse at 90% 50%, rgba(130,195,85,0.18) 0%, transparent 35%);
  pointer-events: none;
}

/* 草地 + 小花 */
.ghibli-bg::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 38%;
  background:
    /* 小花点缀 */
    radial-gradient(circle at 10% 85%, rgba(255,255,150,0.4) 0%, transparent 8%),
    radial-gradient(circle at 18% 78%, rgba(255,200,180,0.35) 0%, transparent 6%),
    radial-gradient(circle at 25% 88%, rgba(255,255,150,0.3) 0%, transparent 7%),
    radial-gradient(circle at 35% 80%, rgba(255,220,200,0.35) 0%, transparent 5%),
    radial-gradient(circle at 48% 90%, rgba(255,255,150,0.4) 0%, transparent 8%),
    radial-gradient(circle at 55% 76%, rgba(255,180,200,0.3) 0%, transparent 6%),
    radial-gradient(circle at 68% 86%, rgba(255,255,150,0.35) 0%, transparent 7%),
    radial-gradient(circle at 78% 82%, rgba(255,200,180,0.3) 0%, transparent 5%),
    radial-gradient(circle at 88% 90%, rgba(255,255,150,0.4) 0%, transparent 8%),
    /* 草地纹理 */
    linear-gradient(0deg,
      rgba(90,170,50,0.5) 0%,
      rgba(100,180,60,0.35) 15%,
      rgba(120,195,75,0.25) 30%,
      rgba(150,210,100,0.15) 50%,
      transparent 100%
    );
  pointer-events: none;
}

/* ===== 全局组件 ===== */

.btn-primary {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFF; border: none; border-radius: 56rpx;
  padding: 28rpx 72rpx; font-size: 34rpx; font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(255,152,0,0.4);
  letter-spacing: 2rpx;
  position: relative; z-index: 1;
}
.btn-primary:active { opacity: 0.85; transform: scale(0.97); }

/* ===== 动画 ===== */

@keyframes popIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes floatIdle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-18rpx); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

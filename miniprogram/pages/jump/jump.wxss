.container {
  height: 100vh; position: relative; overflow: hidden;
  display: flex; flex-direction: column; align-items: center;
}

/* 使用全局背景 */
.ghibli-bg { z-index: 0; }

/* ===== Score bar ===== */
.score-bar {
  position: relative; z-index: 10;
  display: flex; flex-direction: column; align-items: center;
  margin-top: 24rpx; gap: 4rpx;
}
.score-label {
  font-size: 22rpx; color: rgba(255,255,255,0.7); letter-spacing: 4rpx;
}
.score-num {
  font-size: 72rpx; font-weight: 700; color: #FFF;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.score-num.pop {
  animation: scoreBounce 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes scoreBounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.25); }
  100% { transform: scale(1); }
}

/* ===== Canvas ===== */
.canvas-wrap {
  position: relative; z-index: 2;
  width: 100%; flex: 1;
  display: flex; align-items: center; justify-content: center;
}
.game-canvas {
  width: 100%; height: 580rpx;
  border-radius: 24rpx;
}

/* ===== Power bar ===== */
.power-bar {
  position: absolute; bottom: 60rpx; left: 50%; transform: translateX(-50%);
  width: 240rpx; height: 12rpx;
  background: rgba(255,255,255,0.3); border-radius: 8rpx;
  overflow: hidden;
  z-index: 5;
}
.power-fill {
  height: 100%; border-radius: 8rpx;
  transition: width 0.05s linear, background 0.2s;
}

/* ===== Score popup ===== */
.score-popup {
  position: absolute; z-index: 6; pointer-events: none;
  font-size: 32rpx; font-weight: 700;
  transform: translate(-50%, -50%);
  animation: popUp 1s ease-out forwards;
  white-space: nowrap;
}
@keyframes popUp {
  0% { opacity: 1; transform: translate(-50%, -50%) scale(0.5); }
  30% { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
  100% { opacity: 0; transform: translate(-50%, -50%) translateY(-80rpx) scale(1); }
}

/* ===== Instructions overlay ===== */
.instruction-overlay {
  position: absolute; inset: 0; z-index: 4;
  display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.15); border-radius: 24rpx;
  gap: 12rpx;
}
.instruction-title {
  font-size: 36rpx; color: #FFF; font-weight: 700;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.3);
}
.instruction-sub {
  font-size: 24rpx; color: rgba(255,255,255,0.85);
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.2);
}

/* ===== Result overlay ===== */
.result-overlay {
  position: absolute; inset: 0; z-index: 4;
  display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.25); border-radius: 24rpx;
  gap: 16rpx;
}
.result-title {
  font-size: 56rpx; color: #FFF; font-weight: 700;
  text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.3);
}
.result-title.perfect {
  color: #FFD54F; font-size: 60rpx;
}
.result-sub {
  font-size: 28rpx; color: rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
}

/* Retry / Continue buttons */
.retry-btn, .continue-btn, .skip-btn {
  padding: 20rpx 56rpx; border-radius: 48rpx;
  font-size: 30rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}
.retry-btn {
  background: rgba(255,255,255,0.9); color: #5A3A46;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}
.retry-btn:active { transform: scale(0.94); opacity: 0.85; }
.continue-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFF;
  box-shadow: 0 6rpx 24rpx rgba(255,152,0,0.45);
}
.continue-btn:active { transform: scale(0.94); opacity: 0.85; }
.skip-btn {
  background: transparent; color: rgba(255,255,255,0.7);
  font-size: 24rpx; font-weight: 400; padding: 12rpx 32rpx;
}

.bottom-hint {
  position: relative; z-index: 2;
  font-size: 24rpx; color: rgba(60,100,40,0.6);
  padding-bottom: 32rpx;
}

.container { height: 100vh; position: relative; display: flex; flex-direction: column; }

/* 使用全局喜羊羊主题背景 */

/* Floating petals */
.fireflies { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
.firefly {
  position: absolute; font-size: 28rpx;
  animation: petalFloat 6s ease-in-out infinite;
}
.firefly.f1 { top: 25%; left: 18%; animation-delay: 0s; }
.firefly.f2 { top: 35%; left: 35%; animation-delay: 0.8s; }
.firefly.f3 { top: 20%; left: 55%; animation-delay: 1.6s; }
.firefly.f4 { top: 40%; left: 72%; animation-delay: 2.4s; }
.firefly.f5 { top: 28%; left: 85%; animation-delay: 3.2s; }
.firefly.f6 { top: 32%; left: 48%; animation-delay: 4.0s; }
@keyframes petalFloat {
  0%,100% { transform: translate(0,0) rotate(0deg); opacity: 0.4; }
  25% { transform: translate(60rpx,-120rpx) rotate(90deg); opacity: 0.8; }
  50% { transform: translate(-30rpx,-180rpx) rotate(180deg); opacity: 0.5; }
  75% { transform: translate(50rpx,-80rpx) rotate(270deg); opacity: 0.7; }
}

/* ===== Scroll ===== */
.dialogue-scroll {
  flex: 1; position: relative; z-index: 2;
  padding: 20rpx;
}

/* ===== Dialogue Stage ===== */
.dialogue-stage {
  display: flex; flex-direction: column; align-items: center;
  max-width: 640rpx; margin: 0 auto; width: 100%;
}

/* ===== Dialogue Block ===== */
.dialogue-block {
  display: flex; flex-direction: column; align-items: center;
  width: 100%; padding: 40rpx 0;
  animation: blockIn 0.6s ease-out both;
}
@keyframes blockIn {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Phase 0: Tooth character centered ===== */
.tooth-center {
  position: relative; display: flex; justify-content: center;
  margin-bottom: 24rpx;
  animation: floatIdle 4s ease-in-out infinite;
}
.tooth-center.small { margin-bottom: 16rpx; }
@keyframes floatIdle {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
}
.tooth-center.bounce {
  animation: toothPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes toothPop {
  0% { transform: scale(1); }
  30% { transform: scale(1.2) translateY(-20rpx); }
  60% { transform: scale(0.9) translateY(6rpx); }
  100% { transform: scale(1); }
}

.tooth-glow {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,220,180,0.2) 0%, transparent 70%);
}

/* Big tooth */
.big-tooth {
  width: 180rpx; height: 192rpx;
  background: linear-gradient(180deg, #FFFAF8 0%, #FFF0EC 100%);
  border-radius: 50% 50% 42% 42% / 54% 54% 44% 44%;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.15);
  position: relative; display: flex; justify-content: center; align-items: center;
}
.bt-shine {
  position: absolute; top: 22rpx; left: 30rpx;
  width: 60rpx; height: 34rpx;
  background: radial-gradient(ellipse, rgba(255,255,255,0.9) 0%, transparent 70%);
  border-radius: 50%; transform: rotate(-12deg);
}
.bt-eyes { display: flex; gap: 34rpx; margin-top: 10rpx; }
.bt-eye {
  width: 36rpx; height: 40rpx; background: #1A0A14; border-radius: 50%;
  position: relative;
}
.bt-pupil {
  position: absolute; width: 10rpx; height: 10rpx; background: #FFF;
  border-radius: 50%; top: 6rpx; left: 8rpx;
}
.bt-blush {
  position: absolute; bottom: 56rpx;
  width: 36rpx; height: 22rpx;
  background: radial-gradient(ellipse, rgba(255,150,160,0.4) 0%, transparent 70%);
  border-radius: 50%;
}
.bt-mouth {
  position: absolute; bottom: 44rpx;
  width: 32rpx; height: 14rpx;
  border-bottom: 4rpx solid #C08080; border-radius: 0 0 50% 50%;
}

/* Speech bubble */
.speech-box {
  background: rgba(255,255,255,0.92); border-radius: 28rpx;
  padding: 28rpx 36rpx; margin: 0 20rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.12);
  position: relative; text-align: center;
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}
@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.speech-text {
  font-size: 30rpx; color: #3D2B30; line-height: 1.7;
  font-weight: 500;
}
.speech-tail {
  position: absolute; top: -12rpx; left: 50%; transform: translateX(-50%);
  border-left: 12rpx solid transparent; border-right: 12rpx solid transparent;
  border-bottom: 12rpx solid rgba(255,255,255,0.92);
}

/* ===== Symptom Grid - game cards ===== */
.symptom-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center;
  width: 100%; padding: 0 8rpx;
}
.symptom-card {
  width: 168rpx; height: 150rpx;
  background: rgba(255,255,255,0.85); border-radius: 24rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  border: 2rpx solid rgba(200,160,170,0.2);
  transition: all 0.2s ease;
  position: relative;
}
.symptom-card:active {
  background: #E8F5E0; transform: scale(0.93);
}
.symptom-card.picked {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-color: #FFB74D;
  box-shadow: 0 6rpx 24rpx rgba(255,152,0,0.25);
  transform: scale(1.03);
}
.symptom-icon { font-size: 50rpx; }
.symptom-label { font-size: 26rpx; color: #5A3A46; font-weight: 500; }

/* ===== Phase 1 & 2: Deep Talk & Reply ===== */
.deep-phase {
  animation: blockIn 0.6s ease-out both;
}

/* Mini tooth avatar */
.mini-tooth-avatar { margin-bottom: 20rpx; }
.mta-body {
  width: 96rpx; height: 102rpx;
  background: linear-gradient(180deg, #FFFAF8 0%, #FFF0EC 100%);
  border-radius: 48% 48% 38% 38% / 55% 55% 40% 40%;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.1);
  position: relative; display: flex; justify-content: center; align-items: center;
}
.mta-eyes { display: flex; gap: 16rpx; }
.mta-eye {
  width: 18rpx; height: 20rpx; background: #1A0A14; border-radius: 50%;
  position: relative;
}
.mta-eye::after {
  content: ''; position: absolute; width: 6rpx; height: 6rpx;
  background: #FFF; border-radius: 50%; top: 3rpx; left: 3rpx;
}
/* Thinking eyes */
.mini-tooth-avatar.thinking .mta-eye {
  height: 16rpx; border-radius: 50% 50% 0 0;
}
.mta-blush {
  position: absolute; bottom: 29rpx; width: 24rpx; height: 14rpx;
  background: radial-gradient(ellipse, rgba(255,150,160,0.4) 0%, transparent 70%);
  border-radius: 50%;
}
.mta-mouth {
  position: absolute; bottom: 24rpx;
  width: 18rpx; height: 8rpx;
  border-bottom: 3rpx solid #C08080; border-radius: 0 0 50% 50%;
}
.mta-mouth-o {
  position: absolute; bottom: 25rpx;
  width: 10rpx; height: 10rpx;
  border: 3rpx solid #C08080; border-radius: 50%;
}

/* Deep bubble — centered, big, warm */
.deep-bubble {
  background: rgba(255,255,255,0.94); border-radius: 32rpx;
  padding: 32rpx 36rpx; width: 100%; max-width: 560rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  text-align: center; position: relative;
  min-height: 80rpx;
}
.deep-bubble.typing {
  background: rgba(255,255,255,0.88);
}
.deep-text {
  font-size: 30rpx; color: #3D2B30; line-height: 1.85;
  font-weight: 460; letter-spacing: 1rpx;
}
.typing-cursor {
  display: inline; color: #FF9800; font-weight: 700;
  animation: cursorBlink 0.7s ease-in-out infinite;
}
@keyframes cursorBlink {
  0%,100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Question area */
.question-area {
  width: 100%; display: flex; flex-direction: column; align-items: center;
  margin-top: 32rpx; gap: 24rpx;
  animation: fadeUp 0.6s ease-out 0.3s both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.question-box {
  background: linear-gradient(135deg, rgba(255,248,230,0.95), rgba(255,243,210,0.9));
  border-radius: 24rpx; padding: 24rpx 32rpx;
  border: 2rpx solid rgba(255,152,0,0.2);
  text-align: center; width: 100%; max-width: 520rpx;
}
.question-label {
  font-size: 24rpx; color: #FF9800; display: block; margin-bottom: 8rpx;
}
.question-text {
  font-size: 32rpx; color: #5A3A46; font-weight: 600; line-height: 1.6;
  display: block;
}

/* Answer choices */
.answer-choices {
  display: flex; flex-wrap: wrap; gap: 14rpx;
  justify-content: center; width: 100%; max-width: 520rpx;
}
.answer-chip {
  background: rgba(255,255,255,0.8); border-radius: 40rpx;
  padding: 16rpx 28rpx; font-size: 27rpx; color: #5A3A46;
  border: 2rpx solid rgba(150,200,100,0.3);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}
.answer-chip:active {
  background: #E8F5E0; transform: scale(0.94);
}
.answer-chip.chosen {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #FFF; border-color: transparent;
  box-shadow: 0 4rpx 18rpx rgba(255,152,0,0.3);
}

/* Custom answer input */
.custom-answer-area {
  width: 100%; max-width: 520rpx;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
}
.custom-answer-input {
  width: 100%; background: rgba(255,255,255,0.85);
  border-radius: 24rpx; padding: 20rpx 24rpx;
  font-size: 28rpx; color: #3D2B30;
  border: 2rpx solid rgba(200,160,170,0.2);
  min-height: 80rpx; box-sizing: border-box;
}
.custom-send-btn {
  background: #D5C8C8; border-radius: 36rpx;
  padding: 14rpx 40rpx; font-size: 26rpx; color: #FFF;
  transition: all 0.25s;
}
.custom-send-btn.active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  box-shadow: 0 4rpx 16rpx rgba(255,152,0,0.35);
}
.custom-send-btn.active:active { transform: scale(0.9); }

/* Heart connect */
.heart-connect {
  display: flex; flex-direction: column; align-items: center;
  margin-top: 24rpx; gap: 8rpx;
  animation: fadeUp 0.6s ease-out 0.3s both;
}
.heart-icon { font-size: 48rpx; }
.heart-hint { font-size: 24rpx; color: rgba(60,100,40,0.7); }

/* ===== Phase 3: Story ===== */
.story-phase {
  animation: blockIn 0.8s ease-out both;
}
.story-reveal {
  display: flex; flex-direction: column; align-items: center;
  width: 100%;
}
.story-label {
  font-size: 26rpx; color: rgba(60,100,40,0.7);
  margin-bottom: 20rpx; display: block;
}
.story-card {
  background: rgba(255,255,255,0.92); border-radius: 32rpx;
  padding: 36rpx 32rpx; width: 100%;
  box-shadow: 0 8rpx 36rpx rgba(0,0,0,0.12);
  text-align: center;
  animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}
.story-icon { font-size: 56rpx; margin-bottom: 16rpx; display: block; }
.story-preamble {
  font-size: 27rpx; color: #C08090; font-style: italic;
  display: block; line-height: 1.7; margin-bottom: 4rpx;
}
.story-divider {
  width: 80rpx; height: 3rpx;
  background: linear-gradient(90deg, transparent, #A5D6A7, transparent);
  margin: 20rpx auto; border-radius: 2rpx;
}
.story-title {
  font-size: 34rpx; color: #5A3A46; font-weight: 700;
  display: block; margin-bottom: 20rpx;
}
.story-body-wrap {
  text-align: center;
}
.story-text {
  font-size: 29rpx; line-height: 2.0; color: #3D2B30;
  display: block; text-align: left; text-indent: 2em;
}
.story-afterword {
  font-size: 27rpx; color: #C08090; font-style: italic;
  display: block; line-height: 1.7; margin-top: 4rpx;
}

/* Continue */
.continue-area {
  display: flex; flex-direction: column; align-items: center;
  margin-top: 36rpx; gap: 20rpx;
}
.continue-hint {
  font-size: 28rpx; color: #4A7A38;
}
.continue-btn {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  border-radius: 48rpx; padding: 20rpx 56rpx;
  box-shadow: 0 8rpx 28rpx rgba(255,152,0,0.4);
  transition: all 0.2s;
}
.continue-btn:active { transform: scale(0.94); opacity: 0.85; }
.continue-btn text {
  font-size: 30rpx; color: #FFF; font-weight: 600;
}
